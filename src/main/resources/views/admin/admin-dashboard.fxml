<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ptit.doancnpm.controller.admin.AdminDashboardController"
            styleClass="admin-root">

    <left>
        <VBox styleClass="side-bar" prefWidth="270" spacing="8">
            <HBox styleClass="side-brand">
                <Label text="UT" styleClass="side-logo"/>
                <VBox>
                    <Label text="UniTopics" styleClass="side-title"/>
                    <Label text="Admin Console" styleClass="side-subtitle"/>
                </VBox>
            </HBox>

            <Label text="TỔNG QUAN" styleClass="side-section"/>
            <Button text="Dashboard" styleClass="side-menu-active" maxWidth="Infinity"/>
            <Button text="Quản lý tài khoản" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowAccounts"/>
            <Button text="Môn học" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowSubjects"/>
            <Button text="Học kỳ" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowSemesters"/>
            <Button text="Lớp học phần" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowCourseSections"/>
            <Button text="Import sinh viên" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowStudentImport"/>
            <Button text="Báo cáo" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowReports"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Đăng xuất" styleClass="side-logout" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="dashboard-content" spacing="22">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox>
                    <Label fx:id="lblWelcome" text="Xin chào Quản trị viên" styleClass="screen-title"/>
                    <Label text="Quản lý tài khoản, môn học, học kỳ và lớp học phần." styleClass="screen-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblUserInfo" styleClass="user-pill"/>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="stat-card-blue" prefWidth="220">
                    <Label text="Tài khoản" styleClass="stat-label"/>
                    <Label fx:id="lblAccountCount" text="00" styleClass="stat-value"/>
                    <Label fx:id="lblAccountNote" text="Đang tải" styleClass="stat-note"/>
                </VBox>
                <VBox styleClass="stat-card" prefWidth="220">
                    <Label text="Sinh viên" styleClass="stat-label"/>
                    <Label fx:id="lblStudentCount" text="00" styleClass="stat-value"/>
                    <Label fx:id="lblStudentNote" text="Đang tải" styleClass="stat-note"/>
                </VBox>
                <VBox styleClass="stat-card" prefWidth="220">
                    <Label text="Giảng viên" styleClass="stat-label"/>
                    <Label fx:id="lblLecturerCount" text="00" styleClass="stat-value"/>
                    <Label fx:id="lblLecturerNote" text="Đang tải" styleClass="stat-note"/>
                </VBox>
                <VBox styleClass="stat-card" prefWidth="220">
                    <Label text="Lớp học phần" styleClass="stat-label"/>
                    <Label fx:id="lblCourseSectionCount" text="00" styleClass="stat-value"/>
                    <Label fx:id="lblCourseSectionNote" text="Đang tải" styleClass="stat-note"/>
                </VBox>
            </HBox>

            <VBox styleClass="main-card" spacing="14">
                <HBox alignment="CENTER_LEFT">
                    <VBox>
                        <Label text="Thao tác nhanh" styleClass="card-title"/>
                        <Label fx:id="lblDataStatus" text="Đang kiểm tra dữ liệu demo" styleClass="body-muted" wrapText="true"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Kiểm tra dữ liệu" styleClass="btn-outline" onAction="#handleRefreshDashboard"/>
                </HBox>

                <HBox spacing="12">
                    <Button text="+ Tài khoản" styleClass="btn-primary" onAction="#handleCreateAccount"/>
                    <Button text="+ Môn học" styleClass="btn-secondary" onAction="#handleShowSubjects"/>
                    <Button text="+ Học kỳ" styleClass="btn-secondary" onAction="#handleShowSemesters"/>
                    <Button text="+ Lớp học phần" styleClass="btn-secondary" onAction="#handleShowCourseSections"/>
                    <Button text="+ Sinh viên lớp" styleClass="btn-secondary" onAction="#handleShowStudentImport"/>
                    <Button text="Báo cáo" styleClass="btn-outline" onAction="#handleShowReports"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
