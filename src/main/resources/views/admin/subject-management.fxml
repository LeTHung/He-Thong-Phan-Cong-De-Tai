<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ptit.doancnpm.controller.admin.SubjectManagementController"
            styleClass="admin-root">

    <left>
        <VBox styleClass="side-bar" prefWidth="270" spacing="8">
            <HBox styleClass="side-brand">
                <Label text="UT" styleClass="side-logo"/>
                <VBox>
                    <Label text="UniTopics" styleClass="side-title"/>
                    <Label text="Admin Console" styleClass="side-subtitle"/>
                </VBox>
            </HBox>

            <Label text="QUẢN TRỊ" styleClass="side-section"/>
            <Button text="Dashboard" styleClass="side-menu" maxWidth="Infinity" onAction="#handleBackDashboard"/>
            <Button text="Quản lý tài khoản" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowAccounts"/>
            <Button text="Môn học" styleClass="side-menu-active" maxWidth="Infinity"/>
            <Button text="Học kỳ" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowSemesters"/>
            <Button text="Lớp học phần" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowCourseSections"/>
            <Button text="Import sinh viên" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowStudentImport"/>
            <Button text="Báo cáo" styleClass="side-menu" maxWidth="Infinity" onAction="#handleShowReports"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Đăng xuất" styleClass="side-logout" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="dashboard-content" spacing="22">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox>
                    <Label text="Quản lý môn học" styleClass="screen-title"/>
                    <Label text="Thêm, sửa và ngừng sử dụng môn học trong hệ thống." styleClass="screen-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblUserInfo" styleClass="user-pill"/>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="main-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Danh sách môn học" styleClass="card-title"/>
                    <TableView fx:id="tblSubjects" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="colCode" text="Mã môn" prefWidth="120"/>
                            <TableColumn fx:id="colName" text="Tên môn học" prefWidth="260"/>
                            <TableColumn fx:id="colCredits" text="Tín chỉ" prefWidth="80"/>
                            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="140"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblMessage" text="" styleClass="body-muted" wrapText="true"/>
                </VBox>

                <VBox styleClass="main-card admin-form-panel" spacing="12">
                    <Label text="Thông tin môn học" styleClass="card-title"/>

                    <GridPane hgap="10" vgap="10">
                        <Label text="Mã môn" styleClass="caption-strong" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtCode" promptText="VD: CNPM" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                        <Label text="Tên môn học" styleClass="caption-strong" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtName" promptText="Công nghệ phần mềm" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                        <Label text="Số tín chỉ" styleClass="caption-strong" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtCredits" promptText="3" GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                        <Label text="Trạng thái" styleClass="caption-strong" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="cboStatus" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="7"/>

                        <Label text="Mô tả" styleClass="caption-strong" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                        <TextArea fx:id="txtDescription" prefRowCount="4" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Thêm" styleClass="btn-primary" onAction="#handleAddSubject"/>
                        <Button text="Sửa" styleClass="btn-secondary" onAction="#handleUpdateSubject"/>
                    </HBox>
                    <HBox spacing="10">
                        <Button text="Mở dùng" styleClass="btn-outline" onAction="#handleActivateSubject"/>
                        <Button text="Ngừng" styleClass="btn-warning" onAction="#handleDeactivateSubject"/>
                    </HBox>
                    <Button text="Xóa trắng" styleClass="btn-outline" maxWidth="Infinity" onAction="#handleClearForm"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
